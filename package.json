{
  "name": "varal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "pretty-quick && next build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:behavior": "TS_NODE_PROJECT=tsconfig.cucumber.json cucumber-js",
    "install:e2e": "npm install --prefix e2e && npx playwright install --with-deps chromium --prefix e2e",
    "test:e2e": "npm test --prefix e2e",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "inversify": "^7.11.0",
    "js-yaml": "^4.1.1",
    "luxon": "^3.7.2",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reflect-metadata": "^0.2.2",
    "winston": "^3.17.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@prisma/client": "^5.11.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "prisma": "^5.11.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  }
}
